APP_ENV=local
LOG_LEVEL=INFO
HEALTH_AGENT_DATE=
TIMEZONE=Asia/Tokyo
LLM_PROVIDER=mock
LLM_MODEL_NAME=gpt-4.1-mini
LLM_TIMEOUT_SECONDS=30
LLM_MAX_RETRIES=2
FITBIT_CLIENT_MODE=mock
FITBIT_BASE_URL=https://api.fitbit.com
FITBIT_CLIENT_ID=
FITBIT_CLIENT_SECRET=
FITBIT_REFRESH_TOKEN=
HISTORICAL_BOOTSTRAP_ENABLED=true
HISTORICAL_BOOTSTRAP_DAYS=90
HISTORICAL_BOOTSTRAP_MAX_DAYS_PER_RUN=14
GOOGLE_DRIVE_MODE=local
DRIVE_ROOT_FOLDER_ID=HealthAgent
DRIVE_LOCAL_ROOT=.local_drive
DRIVE_OAUTH_CLIENT_ID=
DRIVE_OAUTH_CLIENT_SECRET=
DRIVE_OAUTH_REFRESH_TOKEN=
DRIVE_OAUTH_TOKEN_URI=https://oauth2.googleapis.com/token
LINE_CLIENT_MODE=mock
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=
LINE_USER_ID=mock-user
LINE_RESTRICT_TO_CONFIGURED_USER=true
LINE_WEBHOOK_PATH=/line/webhook
OPENAI_API_KEY=
CLAUDE_API_KEY=
DATABASE_URL=sqlite+pysqlite:///./local.db
DB_ECHO=false
MEAL_CALORIE_ALERT_DELTA=400
MEAL_CALORIE_BALANCE_ALERT_DELTA=300
MEAL_REMINDER_MIN_COUNT=2
MEAL_REMINDER_MIN_CALORIES=900
MEAL_TIMING_HINT_TTL_MINUTES=180
MEAL_POST_IMAGE_TIMING_TTL_MINUTES=120
MEAL_DAY_ROLLOVER_HOUR=5
SLEEP_DEBT_THRESHOLD_MINUTES=390
SLEEP_DEFICIT_ALERT_DELTA_MINUTES=60
RESTING_HR_ELEVATION_BPM=4
BEDTIME_DRIFT_ALERT_MINUTES=45
RECOVERY_SCORE_YELLOW_THRESHOLD=55
RECOVERY_SCORE_RED_THRESHOLD=35
