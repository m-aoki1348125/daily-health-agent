project_id                   = "your-project-id"
region                       = "asia-northeast1"
environment                  = "dev"
db_tier                      = "db-f1-micro"
db_disk_type                 = "PD_SSD"
db_backup_enabled            = false
artifact_registry_repository = "daily-health-agent"
cloud_run_image              = "asia-northeast1-docker.pkg.dev/your-project-id/daily-health-agent/daily-health-agent:latest"
timezone                     = "Asia/Tokyo"
daily_schedule               = "0 9 * * *"
weekly_schedule              = "45 8 * * 0"
monthly_schedule             = "45 8 1 * *"
line_user_id                 = "Uxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
llm_provider                 = "claude"
llm_model_name               = "claude-haiku-4-5"
private_network              = "projects/your-project-id/global/networks/default"
db_password                  = "replace-me"
line_webhook_path            = "/line/webhook"
